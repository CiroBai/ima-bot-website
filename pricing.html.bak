                            <th>功能</th>
                            <th>免费</th>
                            <th>Plus</th>
                            <th>Pro</th>
                            <th>Ultra</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>月度积分</td>
                            <td>—</td>
                            <td>700</td>
                            <td>3200</td>
                            <td>18000</td>
                        </tr>
                        <tr>
                            <td>云端机器</td>
                            <td>❌</td>
                            <td>❌</td>
                            <td>1核2G</td>
                            <td>2核4G</td>
                        </tr>
                        <tr>
                            <td>Bot 功能</td>
                            <td>❌</td>
                            <td>Lite</td>
                            <td>✅</td>
                            <td>✅</td>
                        </tr>
                        <tr>
                            <td>可用模型</td>
                            <td>基础</td>
                            <td>基础</td>
                            <td>Kimi / MiniMax</td>
                            <td>全模型</td>
                        </tr>
                        <tr>
                            <td>基础工具箱</td>
                            <td>✅</td>
                            <td>✅</td>
                            <td>✅</td>
                            <td>✅</td>
                        </tr>
                        <tr>
                            <td>浏览器工具箱</td>
                            <td>❌</td>
                            <td>❌</td>
                            <td>❌</td>
                            <td>✅</td>
                        </tr>
                        <tr>
                            <td>建站工具箱</td>
                            <td>❌</td>
                            <td>❌</td>
                            <td>❌</td>
                            <td>✅</td>
                        </tr>
                        <tr>
                            <td>定时任务</td>
                            <td>❌</td>
                            <td>❌</td>
                            <td>✅</td>
                            <td>✅</td>
                        </tr>
                        <tr>
                            <td>并发数</td>
                            <td>—</td>
                            <td>1</td>
                            <td>1</td>
                            <td>2</td>
                        </tr>
                        <tr>
                            <td>队列数</td>
                            <td>—</td>
                            <td>—</td>
                            <td>10</td>
                            <td>50</td>
                        </tr>
                        <tr>
                            <td>单次运行时长</td>
                            <td>—</td>
                            <td>≤3分钟</td>
                            <td>≤15分钟</td>
                            <td>≤60分钟</td>
                        </tr>
                    </tbody>
                </table>
